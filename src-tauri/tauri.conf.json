{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1423",
    "distDir": "../dist"
  },
  "package": {
    "productName": "USKMaker",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "bundle": {
      "active": false,
      "targets": "all",
      "identifier": "com.uskmaker.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "USKMaker",
        "width": 960,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
