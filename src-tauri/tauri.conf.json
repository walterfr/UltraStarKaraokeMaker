{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1423",
    "distDir": "../dist"
  },
  "package": {
    "productName": "USKMaker",
    "version": "0.3.0"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "protocol": {
        "asset": true,
        "assetScope": ["**"]
      },
      "http": {
        "all": true,
        "request": true,
        "scope": ["https://lrclib.net/api/*"]
      }
    },
    "bundle": {
      "active": true,
      "targets": ["nsis"],
      "identifier": "br.com.walterfr.uskmaker",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/icon.ico"
      ],
      "resources": [
        "../python-sidecar/main.py",
        "../python-sidecar/server.py",
        "../python-sidecar/verify_setup.py",
        "../python-sidecar/requirements.txt",
        "../python-sidecar/pipeline/*.py",
        "../scripts/setup-sidecar.ps1"
      ],
      "windows": {
        "nsis": {
          "installMode": "perMachine",
          "languages": ["PortugueseBR", "English"]
        }
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "USKMaker",
        "width": 960,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
